{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/trending-people-cron",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/trending-mail-cron",
      "schedule": "0 22 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/parse-resume",
      "dest": "/api/parse-resume.js"
    },
    {
      "src": "/api/search-candidates",
      "dest": "/api/search-candidates.js"
    },
    {
      "src": "/api/policy-chat",
      "dest": "/api/policy-chat.js"
    },
    {
      "src": "/api/job-fit-analysis",
      "dest": "/api/job-fit-analysis.js"
    },
    {
      "src": "/api/jd-enhance",
      "dest": "/api/jd-enhance.js"
    },
    {
      "src": "/api/trending-people-cron",
      "dest": "/api/trending-people-cron.js"
    },
    {
      "src": "/api/trending-people",
      "dest": "/api/trending-people.js"
    },
    {
      "src": "/api/trending-mail",
      "dest": "/api/trending-mail.js"
    },
    {
      "src": "/api/trending-mail-cron",
      "dest": "/api/trending-mail.js"
    },
    {
      "src": "/api/screening-mail",
      "dest": "/api/screening-mail.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
